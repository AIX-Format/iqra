{
    "mcpServers": {
        "github-mcp-custom": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-github"
            ],
            "env": {
                "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
            }
        },
        "mcp-server-cloudflare": {
            "command": "npx",
            "args": [
                "-y",
                "@cloudflare/mcp-server-cloudflare"
            ],
            "env": {
                "CLOUDFLARE_API_TOKEN": "${CF_TOKEN}"
            }
        },
        "qdrantdb": {
            "command": "uvx",
            "args": [
                "mcp-server-qdrant"
            ],
            "env": {
                "QDRANT_URL": "http://localhost:6333"
            }
        },
        "gemini-bridge": {
            "command": "uvx",
            "args": [
                "gemini-bridge"
            ]
        }
    }
}