# بسم الله الرحمن الرحيم
# IQRA Environment Variables — Template
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── AIX Sovereign Identity (14-aix) ───────────────────────────────────────────
# Ed25519 private key (base64url-encoded, 32 bytes) for signing AIX manifests
# and Pi Network claim artifacts. Generate via:
#   npx tsx src/scripts_v2/aix_export.ts keygen
# Persist the resulting privateKey here; NEVER commit the populated value.
IQRA_IDENTITY_PRIVATE_KEY_B64URL=
# Stable UUIDv4 for this agent's AIX meta.id. Generate once, then pin.
IQRA_IDENTITY_UUID=
# ISO 8601 creation timestamp for AIX meta.created. Pin once.
IQRA_IDENTITY_CREATED=
# Custom domain override (defaults to axiomid.app)
NEXT_PUBLIC_APP_DOMAIN=axiomid.app

# ── Pi Network ────────────────────────────────────────────────────────────────
# App id from the Pi developer portal.
PI_APP_ID=
# 'sandbox' (Pi testnet, default) or 'production' (Pi mainnet).
PI_ENVIRONMENT=sandbox
# Pi developer browser domain validation key (raw text), served at
# /.well-known/pi-validation-key. Different from the Ed25519 manifest key.
PI_VALIDATION_KEY=

# ── LLM Providers ─────────────────────────────────────────────────────────────
GROQ_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# ── Voice (xAI Grok TTS/STT) ──────────────────────────────────────────────────
# xAI TTS: $4.20/M chars — أرخص من ElevenLabs بـ 14x
# 5 أصوات: Ara (هادئ) | Eve | Leo | Rex | Sal
# IQRA v0.369 يستخدم Ara — هادئ، حكيم، عربي
# https://console.x.ai → API Keys
XAI_API_KEY=

# ── Fast Inference (LPU) — مجاني ──────────────────────────────────────────────
# Cerebras: 1M tok/day مجاناً — أسرع من Groq
# https://cloud.cerebras.ai → Get API Key
CEREBRAS_API_KEY=

# ── Memory & Storage ──────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
QDRANT_URL=
QDRANT_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Knowledge Graph & Topology ────────────────────────────────────────────────
# Logseq — مفتوح المصدر، مجاني، AGPL (الأفضل)
# حمّل من: https://logseq.com (مجاني للأبد)
# أنشئ Vault في أي مجلد، ثم أشر إليه هنا
LOGSEQ_VAULT_PATH=

# Obsidian — يعمل محلياً مجاناً (بدون sync)
# Local REST API plugin مطلوب
OBSIDIAN_API_KEY=
OBSIDIAN_VAULT_PATH=

# InfraNodus — مدفوع (بديل مجاني: Gephi Lite)
# https://gephi.org/gephi-lite — مجاني في المتصفح
INFRANODUS_API_KEY=

# ── Quantum Computing — مجاني ─────────────────────────────────────────────────
# IBM Quantum: 10 min/month على 127 qubits
# https://quantum.ibm.com → Get API Token
IBM_QUANTUM_TOKEN=

# ── Design & UI ───────────────────────────────────────────────────────────────
STITCH_API_KEY=
STITCH_BASE_URL=https://stitch.withgoogle.com

# ── Infrastructure ────────────────────────────────────────────────────────────
CLOUDFLARE_AI_GATEWAY_URL=
CLOUDFLARE_AI_GATEWAY_KEY=
GITHUB_TOKEN=
CF_TOKEN=

# ── Local Runtime ─────────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b
OLLAMA_KV_CACHE_TYPE=q8_0

# ── Mode Flags ────────────────────────────────────────────────────────────────
# true = يستخدم Ollama المحلي بدلاً من API
IQRA_LLM_LOCAL=false
# true = يُفعّل التحليل الطوبولوجي
IQRA_TOPOLOGY=true
# true = يُفعّل محاكاة الكم
IQRA_QUANTUM=false
# true = يكتب الاكتشافات في Obsidian
IQRA_OBSIDIAN=false

# ── Models ────────────────────────────────────────────────────────────────────
GOOGLE_GEMINI_MODEL=gemini-2.5-flash
GROQ_MODEL=llama-3.3-70b-versatile
CEREBRAS_MODEL=llama-3.3-70b
