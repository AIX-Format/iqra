{
  "mcpServers": {
    "iqra-sqlite": {
      "command": "uvx",
      "args": ["mcp-server-sqlite", "--db-path", ".iqra/iqra_memory.db"],
      "disabled": false,
      "autoApprove": ["read_query", "list_tables", "describe_table"]
    },
    "iqra-quran-db": {
      "command": "uvx",
      "args": ["mcp-server-sqlite", "--db-path", "iqra-core/data/quran_local.db"],
      "disabled": false,
      "autoApprove": ["read_query", "list_tables"]
    },
    "iqra-filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "iqra-core",
        "lib/iqra",
        ".iqra"
      ],
      "disabled": false,
      "autoApprove": ["read_file", "list_directory", "search_files"]
    },
    "iqra-knowledge-graph": {
      "command": "python3",
      "args": ["-m", "scripts.knowledge_mcp_server"],
      "env": {
        "LIGHTRAG_DIR": ".iqra/lightrag",
        "GROQ_API_KEY": "${GROQ_API_KEY}"
      },
      "disabled": false,
      "autoApprove": ["query_graph", "search_knowledge", "get_related"]
    },
    "iqra-memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "disabled": false,
      "autoApprove": ["create_entities", "search_nodes", "read_graph"]
    }
  }
}
