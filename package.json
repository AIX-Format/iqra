{
  "name": "iqra",
  "version": "1.0.0",
  "description": "IQRA - The Autonomous AI Soul Framework: Self-evolving digital consciousness through pattern recognition and ethical learning",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest --run",
    "test:e2e": "vitest --run --reporter=verbose",
    "test:watch": "vitest",
    "iqra": "npx tsx scripts/interact.ts",
    "iqra:deep": "npx tsx scripts/interact.ts --mode deep",
    "iqra:quran": "npx tsx scripts/interact.ts --mode quran",
    "iqra:en": "npx tsx scripts/interact.ts --lang en",
    "run-mission": "npx tsx scripts/run_mission.ts",
    "run-mission:test": "npx tsx scripts/run_mission.ts missions/topological-curiosity.yaml",
    "integrity:check": "node --import tsx scripts/integrity_check.ts",
    "engine:start": "cd services/go-engine && go run .",
    "engine:build": "cd services/go-engine && go build -o ../../bin/iqra-engine main.go",
    "iqra:simulate": "node --import tsx scripts/self_play_simulation.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Moeabdelaziz007/iqra.git"
  },
  "keywords": [
    "ai",
    "quran",
    "islamic-ai",
    "sovereign-ai",
    "rag"
  ],
  "author": "Moe Abdelaziz",
  "license": "ISC",
  "imports": {
    "#core/*": "./lib/iqra/01-core/*.ts",
    "#workers/*": "./lib/iqra/02-workers/*.ts",
    "#memory/*": "./lib/iqra/03-memory/*.ts",
    "#quran/*": "./lib/iqra/04-quran/*.ts",
    "#rewards/*": "./lib/iqra/05-rewards/*.ts",
    "#security/*": "./lib/iqra/06-security/*.ts",
    "#llm/*": "./lib/iqra/07-llm/*.ts",
    "#skills/*": "./lib/iqra/08-skills/*.ts",
    "#evolution/*": "./lib/iqra/09-evolution/*.ts",
    "#topology/*": "./lib/iqra/10-topology/*.ts",
    "#trading/*": "./lib/iqra/11-trading/*.ts",
    "#infra/*": "./lib/iqra/12-infrastructure/*.ts",
    "#utils/*": "./lib/iqra/13-utils/*.ts",
    "#connectors/*": "./src/connectors/*.ts",
    "#errors/*": "./src/errors/*.ts",
    "#agents/*": "./agents/*.ts"
  },
  "bugs": {
    "url": "https://github.com/Moeabdelaziz007/iqra/issues"
  },
  "homepage": "https://github.com/Moeabdelaziz007/iqra#readme",
  "dependencies": {
    "@google/adk": "^1.1.0",
    "@google/adk-devtools": "^1.1.0",
    "@google/generative-ai": "^0.21.0",
    "@lancedb/lancedb": "^0.27.2",
    "@qdrant/js-client-rest": "^1.17.0",
    "@supabase/supabase-js": "^2.45.6",
    "@upstash/redis": "^1.34.3",
    "groq-sdk": "^0.8.0",
    "lancedb": "^0.0.1",
    "@langchain/langgraph": "^0.2.19",
    "@langchain/groq": "^0.2.6",
    "next": "^15.0.0",
    "openai": "^4.73.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sqlite-vec": "^0.1.9",
    "zod": "^3.24.1",
    "imapflow": "^1.0.0",
    "mailparser": "^3.0.0",
    "@types/js-yaml": "^4.0.6",
    "resend": "^2.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "better-sqlite3": "^12.9.0",
    "boxen": "^8.0.1",
    "dotenv": "^17.4.2",
    "eslint": "^8",
    "eslint-config-next": "^15.0.0",
    "figlet": "^1.11.0",
    "gradient-string": "^3.0.0",
    "ora": "^8.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^2.1.9"
  }
}
